    Cormen_4ed_ex_6_2_1;
    states{Initial;Final;};
    Actions{
     sort{
       oblectamenta{text{asm{
        OblectamentaDataLabel an_array, an_array_size, an_array_expected_heapify_at_pos_2;
        lea(an_array);
        sti64(ARG0);
        lea(an_array_size);
        ldsi32;
        sti32(ARG2);
        ldi32(2);
        sti32(ARG1);
        //dbg_print_cs_and_regs(0);halt;
        max_heapify{ARG0;ARG1;ARG2;};

        //dbg_print_cs_and_regs(0);
        dbg_print_data(0);

  
       };};};
     };
    };
    t{Initial;Final;sort;};
};

