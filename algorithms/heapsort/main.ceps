/*
p.165 Cormen et. al. Algorithms, 4th ed.

Tail recursive version:

MAX-HEAPIFY(A,i)
 l = left(i)
 r = right(i)
 if (l <= A.heap_size() && A[l] > A[i]) largest = l;
 else largest = i;
 if ( r <= A.heap_size() && A[r] > A[largest]}) largest = r;
 if (largest != i)
  swap(A[i], A[largest]);
  MAX-HEAPIFY(A,largest);

Iterative version:

MAX-HEAPIFY-ITER(A,i)
while true 
 l = left(i)
 r = right(i)
 if (l <= A.heap_size() && A[l] > A[i]) largest = l;
 else largest = i;
 if (r <= A.heap_size() && A[r] > A[largest]}) largest = r;
 if (largest != i)
  swap(A[i], A[largest]);
 else break;

*/

macro max_heapify{
    val A = hd(arglist);
    val i = hd(tail(arglist));
    val size = hd(tail(tail(arglist)));
    val l = R0;
    val r = R1;
    val w = R2;
    ldi32(4);sti32(w); // w <- 4
    OblectamentaCodeLabel max_heapify_start, max_heapify_end;
max_heapify_start;
    val largest = R3;
    ldi32(i);
    ldi32(1);
    shli32;
    ldi32(1);
    addi32;
    sti32(l); // l <- 2*i + 1
    ldi32(i);
    ldi32(1);
    shli32;
    ldi32(2);
    addi32;
    sti32(r); // r <- 2*i + 2
    ldi32(size);
    ldi32(l);
    OblectamentaCodeLabel else_1, end_if_1;
    bgteq(else_1);
    
    ldi64(A);
    ldi32(l);
    ldi32(w);
    muli32;
    ui32toui64;
    addi64;
    ldsi32;

    ldi64(A);
    ldi32(i);
    ldi32(w);
    muli32;
    ui32toui64;
    addi64;
    ldsi32;
    bgteq(else_1);
    ldi32(l);
    sti32(largest);
    buc(end_if_1);
else_1;
    ldi32(i);
    sti32(largest);
end_if_1;            // if (l <= A.heap_size() && A[l] > A[i]) largest = l; else largest = i;

    OblectamentaCodeLabel end_if_2;
    ldi32(size);
    ldi32(r);
    bgteq(end_if_2);
    ldi64(A);
    ldi32(r);
    ldi32(4);
    muli32;
    ui32toui64;
    addi64;
    ldsi32;
    ldi64(A);
    ldi32(largest);
    ldi32(4);
    muli32;
    ui32toui64;
    addi64;
    ldsi32;    
    bgteq(end_if_2);
    ldi32(r);
    sti32(largest);
    

end_if_2;           //if (r <= A.heap_size() && A{r] > A[largest]}) largest = r;

    ldi32(largest);
    ldi32(i);
    beq(max_heapify_end);
    //if (largest != i)
    val i_addr = R4;
    val largest_addr = R5;
    val i_val = R6;
    val largest_val = R7;
    ldi64(A);
    ldi32(i);
    ldi32(w);
    muli32;
    ui32toui64;
    addi64;
    sti64(i_addr);
    ldi64(A);
    ldi32(largest);
    ldi32(w);
    muli32;
    ui32toui64;
    addi64;
    sti64(largest_addr);
    ldi64(i_addr);
    ldsi32;
    sti32(i_val);
    ldi64(largest_addr);
    ldsi32;
    sti32(largest_val);
    ldi32(i_val);
    ldi64(largest_addr);
    stsi32;
    ldi32(largest_val);
    ldi64(i_addr);
    stsi32;
    //swap(A[i], A[largest]);
    ldi32(largest);
    sti32(i);
    //dbg_print_data(0);
    //dbg_print_cs_and_regs(0);    

    buc(max_heapify_start);
    
max_heapify_end;
    //dbg_print_data(0);
    //dbg_print_cs_and_regs(0);    
};

